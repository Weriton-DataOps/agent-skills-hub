# lixo de SO / editor
.DS_Store
Thumbs.db
desktop.ini
.vscode/

# nunca versionar dependências ou zips de origem
node_modules/
*.zip

# git aninhado acidental dentro de skills/agents
**/.git/

# estado de runtime do curador (por máquina; não versionar)
agents/curator/queue/
agents/curator/runs/
agents/curator/reports/parked-review.md

# bytecode python
__pycache__/
*.pyc

# config local do Claude Code (por máquina)
.claude/settings.local.json

# drop-zone de sugestões (transiente; o que vale vira skill commitada)
contributions/inbox/*
!contributions/inbox/.gitkeep
contributions/processed/

# SafeGate = setup local (raiz) do agente de segurança (NUNCA subir; contém .env com segredo)
# barra inicial = só a pasta da RAIZ (não pega agents/safegate/, que é o agente publicável)
/SafeGate/

# nunca versionar segredos
**/.env
!**/.env.example
